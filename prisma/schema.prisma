generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id          String            @id @default(uuid())
  name        String
  email       String            @unique
  role        UserRoles
  active      Boolean           @default(true)
  locationId  String
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  location    Location          @relation(fields: [locationId], references: [id])
  assignments AssetAssignment[]
  auditLogs   AuditLog[]
}

model Colaborators {
  id          String            @id @default(uuid())
  name        String
  email       String            @unique
  active      Boolean           @default(true)
  locationId  String
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  location    Location          @relation(fields: [locationId], references: [id])
  assignments AssetAssignment[]
  auditLogs   AuditLog[]
}

model Asset {
  id           String            @id @default(uuid())
  assetTag     String            @unique
  serialNumber String?           @unique
  brand        String
  model        String
  status       AssetStatus
  cost         Decimal?
  purchaseDate DateTime?
  warrantyEnd  DateTime?
  createdAt    DateTime          @default(now())
  assetTypeId  String
  locationId   String
  assetType    AssetType         @relation(fields: [assetTypeId], references: [id])
  location     Location          @relation(fields: [locationId], references: [id])
  assignments  AssetAssignment[]
}

model AssetType {
  id               String            @id @default(uuid())
  name             String
  category         String
  assets           Asset[]
  assetAssignments AssetAssignment[]
}

model Location {
  id           String         @id @default(uuid())
  name         String
  room         String?
  assets       Asset[]
  users        User[]
  colaborators Colaborators[]
  pheriperals  Pheriperals[]
}

model AssetAssignment {
  id               String        @id @default(uuid())
  assetId          String
  userId           String
  assignedAt       DateTime      @default(now())
  expectedReturnAt DateTime?
  returnedAt       DateTime?
  assignmentType   AssetAssign
  colaboratorsId   String?
  assetTypeId      String
  asset            Asset         @relation(fields: [assetId], references: [id])
  assetType        AssetType     @relation(fields: [assetTypeId], references: [id])
  colaborators     Colaborators? @relation(fields: [colaboratorsId], references: [id])
  user             User          @relation(fields: [userId], references: [id])
}

model AuditLog {
  id             String        @id @default(uuid())
  userId         String
  entity         String
  entityId       String
  action         String
  oldValue       Json?
  newValue       Json?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  colaboratorsId String?
  colaborators   Colaborators? @relation(fields: [colaboratorsId], references: [id])
  user           User          @relation(fields: [userId], references: [id])
}

model Pheriperals {
  id                String          @id @default(uuid())
  model             String
  amout             Int
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt
  deleted_at        Boolean         @default(false)
  locationId        String
  location          Location        @relation(fields: [locationId], references: [id])
  pheriperalsTypeId String
  pheriperalsType   PheriperalsType @relation(fields: [pheriperalsTypeId], references: [id])
}

model PheriperalsType {
  id          String        @id @default(uuid())
  name        String        @unique
  category    String?
  pheriperals Pheriperals[]
}

enum UserRoles {
  ADMIN
  ANALIST
  ASSETS
  FIELD_DESK
  USER
}

enum AssetStatus {
  ESTOQUE
  EM_USO
  MANUTENCAO
  DESCARTE
  PERDIDO
}

enum AssetAssign {
  ONBOARDING
  TROCA
  EMPRESTIMO
}
